---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				max-width: 640px;
				margin-bottom: 2rem;
				font-size: 1.125rem;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
			}
			.latest-posts h2 {
				margin-bottom: 1rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 2.5rem 0;
			}
			.post-list li {
				margin-bottom: 1.25rem;
			}
			.post-list a {
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post-list a:hover .post-title {
				color: rgb(var(--accent));
			}
			.post-title {
				font-size: 1.1rem;
				font-weight: 600;
				margin: 0;
				transition: color 0.2s ease;
			}
			.post-meta {
				display: flex;
				gap: 1rem;
				align-items: baseline;
				margin-top: 0.2rem;
			}
			.post-date {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				min-width: 5rem;
				flex-shrink: 0;
			}
			.post-description {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
				margin: 0;
			}
			.all-posts {
				font-size: 0.95rem;
			}
			.topics {
				margin-bottom: 2.5rem;
			}
			.topics h2 {
				margin-bottom: 0.75rem;
			}
			.topics ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.topics li {
				background: rgb(var(--gray-light));
				padding: 0.4rem 0.85rem;
				border-radius: 2rem;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.cta {
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}
			.cta a {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>{SITE_TITLE}</h1>

			<p class="intro">
				Software engineer with too many past lives — QA, BA, PM, and now dev. This is where I put my thoughts.
			</p>

			<section class="latest-posts">
				<h2>Latest posts</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<div class="post-meta">
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
									<p class="post-description">{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>
				<a class="all-posts" href="/blog">View all posts &rarr;</a>
			</section>


			<p class="cta">
				Find me on <a href="https://www.linkedin.com/in/daria-trainor/" target="_blank">LinkedIn</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
